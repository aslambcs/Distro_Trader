<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fbr_sale_type_form" model="ir.ui.view">
        <field name="name">fbr.reason.form</field>
        <field name="model">fbr.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Sale Type"/>
                        </group>
                   
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fbr_sale_type_list" model="ir.ui.view">
        <field name="name">fbr.reason.list</field>
        <field name="model">fbr.reason</field>
        <field name="arch" type="xml">

             <list string="FBR Reason" editable="bottom" default_order="sequence">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
             
        </list>
        </field>
    </record>

    <record id="action_fbr_reason" model="ir.actions.act_window">
        <field name="name">FBR Reason</field>
        <field name="res_model">fbr.reason</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>
