<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fbr_uom_form" model="ir.ui.view">
        <field name="name">fbr.uom.form</field>
        <field name="model">fbr.uom</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="FBR uom"/>
                        </group>
                   
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fbr_uom_list" model="ir.ui.view">
        <field name="name">fbr.uom.list</field>
        <field name="model">fbr.uom</field>
        <field name="arch" type="xml">

             <list string="FBR UOM" editable="bottom" default_order="sequence">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
             
        </list>
        </field>
    </record>

    <record id="action_fbr_uom" model="ir.actions.act_window">
        <field name="name">FBR UOM</field>
        <field name="res_model">fbr.uom</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>
