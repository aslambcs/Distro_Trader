<odoo>
    <record id="view_tax_form_inherit_fbr" model="ir.ui.view">
        <field name="name">account.tax.form.inherit.fbr</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <!-- Add after existing fields -->
                  <xpath expr="//field[@name='type_tax_use']" position="after">
                
                
                <field name="fbr_tax_label_id"  options="{'no_open': True, 'no_create': True, 'no_create_edit':True}" />
                <field name="fbr_tax_type_id"  options="{'no_open': True, 'no_create': True, 'no_create_edit':True}" />
            </xpath>
        </field>
    </record>
</odoo>