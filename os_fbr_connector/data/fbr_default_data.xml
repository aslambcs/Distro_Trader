    <record id="fbr_sro_schedule_6th" model="fbr.sro.schedule.no">
        <field name="name">6th Schd Table I</field>
        <field name="sequence">3</field>
    </record>
    <record id="fbr_sro_schedule_eighth" model="fbr.sro.schedule.no">
        <field name="name">EIGHTH SCHEDULE Table 1</field>
        <field name="sequence">4</field>
    </record>




    <!-- Data for FBR SRO Item Serial Number -->
    <record id="sro_item_serial_1i" model="fbr.sro.item.serial.no">
        <field name="name">1(i)</field>
