    <record id="sro_item_serial_1" model="fbr.sro.item.serial.no">
        <field name="name">1</field>
        <field name="sequence">2</field>
    </record>

    <record id="sro_item_serial_100" model="fbr.sro.item.serial.no">
        <field name="name">100</field>
